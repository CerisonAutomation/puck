# ============================================================
# Christian Property Management — CPM App Environment Variables
# ============================================================
# Copy to .env.local and fill in your values
# NEVER commit .env.local to git

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_SERVER_URL=https://your-domain.vercel.app
PAYLOAD_SECRET=generate-32-char-random-string-here

# ── Database (Supabase Postgres) ─────────────────────────────
# Get from: Supabase Dashboard > Settings > Database > Connection string
DATABASE_URI=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ── Storage (Vercel Blob) ─────────────────────────────────────
# Get from: Vercel Dashboard > Storage > Blob > Connect
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxx

# ── Email (Resend) ────────────────────────────────────────────
# Get from: resend.com > API Keys
RESEND_API_KEY=re_xxxx

# ── Payments (Stripe) ─────────────────────────────────────────
# Get from: dashboard.stripe.com > Developers > API keys
STRIPE_SECRET_KEY=sk_live_xxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxx

# ── Monitoring (Sentry) ───────────────────────────────────────
# Get from: sentry.io > Settings > Projects > Client Keys
SENTRY_DSN=https://xxxx@o0.ingest.sentry.io/xxxx
SENTRY_AUTH_TOKEN=sntrys_xxxx
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@o0.ingest.sentry.io/xxxx

# ── Analytics (Vercel) ───────────────────────────────────────
# Auto-injected by Vercel — no config needed in prod
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=auto

# ── Puck Editor ──────────────────────────────────────────────
NEXT_PUBLIC_PUCK_EDITOR_ENABLED=true
