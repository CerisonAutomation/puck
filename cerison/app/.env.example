# ============================================================
# CPM × Payload CMS × Puck — Environment Variables
# Copy to .env.local and fill in your values
# ============================================================

# --- App ---
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
NODE_ENV=development

# --- Payload CMS ---
PAYLOAD_SECRET=your-super-secret-payload-key-min-32-chars

# --- Database (Supabase Postgres) ---
# Get from: Supabase Dashboard > Project Settings > Database > Connection String > URI
DATABASE_URI=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# --- Storage (Vercel Blob) ---
# Get from: Vercel Dashboard > Storage > Blob > your-store > .env.local
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxx

# --- Email (Resend) ---
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Stripe ---
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Get from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Sentry (Error Monitoring) ---
# Get from: https://sentry.io
SENTRY_DSN=https://xxxxxxxx@oxxxxxxx.ingest.sentry.io/xxxxxxx
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=cpm-puck
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Preview (Draft Mode) ---
PREVIEW_SECRET=your-preview-secret-token

# --- Analytics (Vercel) ---
# Auto-injected by Vercel — no action needed in production
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=
